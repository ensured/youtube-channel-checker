# YouTube Data API v3 key
YOUTUBE_API_KEY=

# Resend API key (https://resend.com/)
RESEND_API_KEY=

# Email address to receive notifications
NOTIFICATION_EMAIL=

# YouTube channel IDs to monitor (comma-separated)
# Format: channel IDs or @username (e.g., UCG8R0ZMHBkRzBT1DWK9wT5w,@babykeem)
CHANNEL_IDS=

# Check interval in seconds (default: 30 minutes)
CHECK_INTERVAL=1800
